# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── Database ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection string
# Replace scheme with postgresql+asyncpg://

DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@db.your-project.supabase.co:5432/postgres

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
# Webhook secret: run `stripe listen --forward-to localhost:8000/billing/webhook`

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Resend ──────────────────────────────────────────────────────────────────
# Found in: resend.com → API Keys
# RESEND_FROM_EMAIL must be a verified sender domain

RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── App URLs ─────────────────────────────────────────────────────────────────
# Used for Stripe redirect URLs, password-reset links, and CORS

# Frontend origin (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Backend origin — set to your Railway URL in production
NEXT_PUBLIC_API_URL=http://localhost:8000

# Space-separated list of allowed CORS origins (backend reads this)
CORS_ORIGINS_STR=http://localhost:3000

# ─── App ─────────────────────────────────────────────────────────────────────

APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
